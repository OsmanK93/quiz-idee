<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diagnostic Créatif — Mouslimarketing</title>
<style>
  :root {
    --vert: #3a9e2f;
    --vert-fonce: #1e5c17;
    --vert-pale: #f0faea;
    --noir: #0f0f0f;
    --gris-dark: #3a3a3a;
    --gris: #6b6b6b;
    --gris-light: #f5f5f5;
    --border: #e4e4e4;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: Arial, sans-serif;
    background: #fafafa;
    color: var(--noir);
    min-height: 100vh;
  }

  .topbar {
    background: white;
    border-bottom: 1px solid var(--border);
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .topbar img { height: 44px; }
  .topbar-label {
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--gris);
    text-transform: uppercase;
  }

  .quiz-wrapper { max-width: 680px; margin: 0 auto; padding: 40px 24px 80px; }

  /* PROGRESS */
  .progress-wrap { margin-bottom: 28px; }
  .progress-top { display: flex; justify-content: space-between; margin-bottom: 8px; }
  .progress-label { font-family: monospace; font-size: 11px; color: var(--gris); letter-spacing: 0.1em; text-transform: uppercase; }
  .progress-count { font-family: monospace; font-size: 11px; color: var(--vert); font-weight: 700; }
  .progress-bar-bg { height: 4px; background: var(--border); width: 100%; }
  .progress-bar-fill { height: 4px; background: var(--vert); transition: width 0.4s ease; width: 0%; }

  /* QUESTION */
  .question-card { background: white; border: 1px solid var(--border); padding: 32px; }
  .q-number { font-family: monospace; font-size: 10px; color: var(--vert); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 12px; display: block; }
  .q-text { font-size: 20px; font-weight: 700; color: var(--noir); line-height: 1.4; margin-bottom: 24px; }
  .options { display: flex; flex-direction: column; gap: 10px; }
  .option {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 16px; border: 1px solid var(--border);
    background: #fafafa; cursor: pointer; transition: all 0.15s;
  }
  .option:hover { border-color: var(--vert); background: var(--vert-pale); }
  .option.selected { border-color: var(--vert); background: var(--vert-pale); }
  .option-letter { font-family: monospace; font-size: 11px; font-weight: 700; color: var(--vert); min-width: 18px; margin-top: 2px; flex-shrink: 0; }
  .option-text { font-size: 14px; color: var(--gris-dark); line-height: 1.55; }
  .option.selected .option-text { color: var(--noir); font-weight: 600; }

  .q-nav { display: flex; justify-content: flex-end; margin-top: 20px; }
  .btn-next {
    background: #ccc; color: white; font-family: monospace;
    font-size: 11px; font-weight: 700; padding: 12px 24px;
    border: none; cursor: not-allowed; letter-spacing: 0.1em; text-transform: uppercase;
  }
  .btn-next.active { background: var(--noir); cursor: pointer; }
  .btn-next.active:hover { background: var(--vert); }

  /* LOADING */
  #screen-loading { display: none; text-align: center; padding: 80px 0; }
  .loader-text { font-size: 20px; font-weight: 700; color: var(--noir); margin-bottom: 24px; }
  .dots { display: flex; gap: 8px; justify-content: center; }
  .dot { width: 10px; height: 10px; background: var(--vert); border-radius: 50%; animation: bounce 1.2s ease infinite; }
  .dot:nth-child(2) { animation-delay: 0.2s; }
  .dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }

  /* RÉSULTAT */
  #screen-result { display: none; }
  .result-header { text-align: center; padding: 36px 28px; background: white; border: 1px solid var(--border); margin-bottom: 16px; }
  .result-badge { display: inline-block; font-family: monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--vert); border: 1px solid var(--vert); padding: 4px 12px; margin-bottom: 16px; }
  .result-emoji { font-size: 48px; margin-bottom: 14px; }
  .result-profil-name { font-size: 36px; font-weight: 900; color: var(--noir); margin-bottom: 8px; line-height: 1.1; }
  .result-profil-tag { font-family: monospace; font-size: 11px; color: var(--gris); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 18px; }
  .result-desc { font-size: 15px; color: var(--gris-dark); line-height: 1.75; max-width: 500px; margin: 0 auto; }

  .scores-card { background: white; border: 1px solid var(--border); padding: 24px; margin-bottom: 16px; }
  .scores-title { font-family: monospace; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gris); margin-bottom: 18px; }
  .score-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .score-label { font-size: 13px; font-weight: 600; color: var(--gris-dark); min-width: 120px; }
  .score-bar-bg { flex: 1; height: 6px; background: var(--gris-light); border-radius: 3px; overflow: hidden; }
  .score-bar-fill { height: 6px; background: var(--vert); border-radius: 3px; width: 0; transition: width 1s ease 0.2s; }
  .score-pct { font-family: monospace; font-size: 12px; font-weight: 700; color: var(--noir); min-width: 34px; text-align: right; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .insight-card { background: white; border: 1px solid var(--border); padding: 20px; }
  .insight-card h4 { font-family: monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gris); margin-bottom: 12px; }
  .insight-card ul { list-style: none; padding: 0; }
  .insight-card ul li { font-size: 13px; color: var(--gris-dark); padding: 4px 0 4px 18px; position: relative; line-height: 1.5; }
  .insight-card ul li::before { position: absolute; left: 0; }
  .forces li::before { content: "✓"; color: var(--vert); font-weight: 700; }
  .points li::before { content: "→"; color: var(--gris); }

  .chapitres-card { background: var(--vert-pale); border: 1px solid rgba(58,158,47,0.25); padding: 24px; margin-bottom: 16px; }
  .chapitres-card h4 { font-family: monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--vert-fonce); margin-bottom: 14px; }
  .chap-list { display: flex; flex-direction: column; gap: 10px; }
  .chap-item { display: flex; gap: 12px; align-items: flex-start; }
  .chap-num { font-family: monospace; font-size: 11px; font-weight: 700; color: white; background: var(--vert); padding: 3px 8px; flex-shrink: 0; margin-top: 1px; }
  .chap-info h5 { font-size: 13px; font-weight: 700; color: var(--noir); margin-bottom: 2px; }
  .chap-info p { font-size: 12px; color: var(--gris); line-height: 1.5; }

  .cta-final { background: white; border: 1px solid var(--border); padding: 32px; text-align: center; }
  .cta-final h3 { font-size: 24px; font-weight: 900; color: var(--noir); margin-bottom: 10px; line-height: 1.2; }
  .cta-final p { font-size: 14px; color: var(--gris); line-height: 1.7; max-width: 440px; margin: 0 auto 18px; }
  .prix-cta { display: flex; gap: 8px; align-items: baseline; justify-content: center; margin-bottom: 4px; }
  .prix-barre { font-family: monospace; font-size: 14px; color: #ccc; text-decoration: line-through; }
  .prix-val { font-size: 38px; font-weight: 900; color: var(--noir); }
  .prix-launch { font-family: monospace; font-size: 10px; color: var(--vert); letter-spacing: 0.12em; text-transform: uppercase; display: block; margin-bottom: 18px; }
  .btn-cta { display: inline-block; background: var(--vert); color: white; font-family: monospace; font-size: 12px; font-weight: 700; padding: 16px 32px; text-decoration: none; letter-spacing: 0.08em; text-transform: uppercase; transition: background 0.2s; }
  .btn-cta:hover { background: var(--vert-fonce); }
  .cta-note { font-size: 11px; color: #bbb; font-family: monospace; margin-top: 10px; }

  .btn-retake { background: none; border: none; font-family: monospace; font-size: 11px; color: var(--gris); text-decoration: underline; cursor: pointer; margin: 20px auto 0; display: block; }

  @media (max-width: 560px) {
    .two-col { grid-template-columns: 1fr; }
    .question-card { padding: 20px; }
    .quiz-wrapper { padding: 24px 16px 60px; }
    .topbar { padding: 12px 16px; }
  }
</style>
</head>
<body>

<div class="topbar">
  <img src="data:image/jpeg;base64," alt="Mouslimarketing">
