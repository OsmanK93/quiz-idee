function renderQuestion() {
  selected = null;
  var q = questions[currentQ];
  var letters = ["A","B","C","D"];
  var pct = Math.round((currentQ / questions.length) * 100);

  document.getElementById("q-current").textContent = currentQ + 1;
  document.getElementById("q-pct").textContent = pct + "%";
  document.getElementById("progress-fill").style.width = pct + "%";
  document.getElementById("q-num-label").textContent = "Question " + (currentQ < 9 ? "0" : "") + (currentQ + 1);
  document.getElementById("q-text").textContent = q.text;

  var wrap = document.getElementById("options-wrap");
  wrap.innerHTML = "";
  for (var i = 0; i < q.options.length; i++) {
    (function(idx) {
      var div = document.createElement("div");
      div.className = "option";
      var letter = document.createElement("span");
      letter.className = "option-letter";
      letter.textContent = letters[idx];
      var text = document.createElement("span");
      text.className = "option-text";
      text.textContent = q.options[idx].text;
      div.appendChild(letter);
      div.appendChild(text);
      div.onclick = function() { selectOption(idx); };
      wrap.appendChild(div);
    })(i);
  }

  document.getElementById("btn-next").className = "btn-next";
}

function selectOption(idx) {
  selected = idx;
  var opts = document.querySelectorAll(".option");
  for (var i = 0; i < opts.length; i++) {
    if (i === idx) { opts[i].className = "option selected"; }
    else { opts[i].className = "option"; }
  }
  document.getElementById("btn-next").className = "btn-next active";
}

function nextQuestion() {
  if (selected === null) return;
  var s = questions[currentQ].options[selected].scores;
  var keys = Object.keys(s);
  for (var i = 0; i < keys.length; i++) { scores[keys[i]] += s[keys[i]]; }
  currentQ++;
  if (currentQ < questions.length) {
    renderQuestion();
  } else {
    showLoading();
  }
}

function showLoading() {
  document.getElementById("screen-quiz").style.display = "none";
  document.getElementById("screen-loading").style.display = "block";
  setTimeout(showResult, 2000);
}

function showResult() {
  document.getElementById("screen-loading").style.display = "none";
  document.getElementById("screen-result").style.display = "block";

  var keys = Object.keys(scores);
  var dominant = keys[0];
  for (var i = 1; i < keys.length; i++) {
    if (scores[keys[i]] > scores[dominant]) dominant = keys[i];
  }
  var p = profils[dominant];

  document.getElementById("r-emoji").textContent = p.emoji;
  document.getElementById("r-name").textContent = p.name;
  document.getElementById("r-tag").textContent = p.tag;
  document.getElementById("r-desc").textContent = p.desc;

  var fHtml = "";
  for (var i = 0; i < p.forces.length; i++) fHtml += "<li>" + p.forces[i] + "</li>";
  document.getElementById("r-forces").innerHTML = fHtml;

  var pHtml = "";
  for (var i = 0; i < p.points.length; i++) pHtml += "<li>" + p.points[i] + "</li>";
  document.getElementById("r-points").innerHTML = pHtml;

  var cHtml = "";
  for (var i = 0; i < p.chapitres.length; i++) {
    var c = p.chapitres[i];
    cHtml += "<div class='chap-item'><span class='chap-num'>" + c.num + "</span><div class='chap-info'><h5>" + c.titre + "</h5><p>" + c.desc + "</p></div></div>";
  }
  document.getElementById("r-chapitres").innerHTML = cHtml;

  var total = 0;
  var skeys = Object.keys(scores);
  for (var i = 0; i < skeys.length; i++) total += scores[skeys[i]];
  if (total === 0) total = 1;

  var labels = {G:"Generation",B:"Deblocage",E:"Execution",S:"Communication"};
  var sorted = skeys.slice().sort(function(a,b){return scores[b]-scores[a];});
  var bHtml = "";
  for (var i = 0; i < sorted.length; i++) {
    var k = sorted[i];
    var pct = Math.round((scores[k]/total)*100);
    bHtml += "<div class='score-row'><span class='score-label'>" + labels[k] + "</span><div class='score-bar-bg'><div class='score-bar-fill' id='bar-" + k + "' style='width:0%'></div></div><span class='score-pct'>" + pct + "%</span></div>";
  }
  document.getElementById("scores-bars").innerHTML = bHtml;

  setTimeout(function(){
    for (var i = 0; i < sorted.length; i++) {
      var k = sorted[i];
      var pct = Math.round((scores[k]/total)*100);
      var el = document.getElementById("bar-" + k);
      if (el) el.style.width = pct + "%";
    }
  }, 150);

  document.getElementById("screen-result").scrollIntoView({behavior:"smooth"});
}

function resetQuiz() {
  currentQ = 0; selected = null; scores = {G:0,B:0,E:0,S:0};
  document.getElementById("screen-result").style.display = "none";
  document.getElementById("screen-loading").style.display = "none";
  document.getElementById("screen-quiz").style.display = "block";
  renderQuestion();
  window.scrollTo({top:0,behavior:"smooth"});
}

// Demarrage robuste - fonctionne dans tous les contextes
if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", init);
} else {
  init();
}
</script>
</body>
</html>
